---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/WhatsApp Image 2026-03-14 at 2.12.00 PM.jpeg?url';
import luisCvEs from '../assets/CV/CV LUIS GARNICA.pdf?url';
import luisCvEn from '../assets/CV/CV LUIS GARNICA ENG.pdf?url';

const translations = {
  greeting: { 
    en: "Hello, I'm", 
    es: "Hola, soy" 
  },
  name: { 
    en: "Luis Garnica", 
    es: "Luis Garnica" 
  },
  description: { 
		en: "Full Stack Developer and future Systems Engineer, specialized in cross-platform development and process automation using AI and n8n. I have experience creating comprehensive clinical systems while working with agile and traditional methodologies. I focus on building modern technological solutions with rigorous attention to detail to ensure the best user and patient experience.", 
		es: "Desarrollador Full Stack y próximo Ingeniero de Sistemas, especializado en el desarrollo multiplataforma y la automatización de procesos utilizando IA y n8n. Cuento con experiencia en la creación de sistemas clínicos integrales trabajando con metodologías ágiles y tradicionales. Centrado en construir soluciones tecnológicas modernas con una rigurosa atención al detalle para garantizar la mejor experiencia del usuario y del paciente." 
  },
  availability: {
    en: "Open to work",
    es: "Disponible para trabajar"
  },
  viewProjects: { 
    en: "View Projects", 
    es: "Ver Proyectos" 
  },
  getInTouch: { 
    en: "Get in Touch", 
    es: "Contactar" 
  },
	roleTitle: {
		en: "Full Stack Developer",
		es: "Full Stack Developer"
	},
	downloadCv: {
		en: "Download CV",
		es: "Descargar CV"
	},
  about: { 
    en: "About Me", 
    es: "Sobre mí" 
  },
  aboutDesc: {
		es: "Soy Estudiante de último trimestre de Ingeniería de Sistemas con enfoque en el desarrollo de software multiplataforma, la automatización de procesos y soluciones basadas en computación emergente. Especialista en la creación de interfaces dinámicas y nativas utilizando ReactJS, Flutter y Dart, complementado con un sólido dominio de Python, Java y JavaScript. Experiencia en el diseño y gestión de arquitecturas de datos relacionales y NoSQL, así como en la implementación de modelos de redes neuronales y flujos de trabajo automatizados. Conocimiento en uso de Git/GitHub bajo metodologías ágiles y tradicionales, orientado a optimizar procesos tecnológicos y desarrollar soluciones innovadoras de alto impacto.",
		en: "I am a final-term Systems Engineering student focused on cross-platform software development, process automation, and solutions based on emerging computing. I specialize in building dynamic, native interfaces with ReactJS, Flutter, and Dart, complemented by strong proficiency in Python, Java, and JavaScript. I have experience designing and managing relational and NoSQL data architectures, as well as implementing neural network models and automated workflow pipelines. Familiar with Git/GitHub under agile and traditional methodologies, I am driven to optimize technological processes and deliver high-impact innovative solutions."
  },
  tech: { 
    en: "Tech Stack", 
    es: "Tecnologías" 
  }
};

---

<Layout title={`Home | Luis Garnica`}>
	<Header />
	
	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<section class="max-w-3xl mx-auto min-h-[calc(100vh-5rem)] flex flex-col justify-center pt-32 sm:pt-48 pb-16 sm:pb-24 fade-in">
			<div class="flex flex-col items-center gap-6 sm:gap-8 text-center enter-up">
				<div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
					<div class="w-28 h-28 sm:w-32 sm:h-32 md:w-40 md:h-40 rounded-full bg-gray-100 dark:bg-gray-800 border-2 border-gray-300 dark:border-gray-600 flex items-center justify-center overflow-hidden animated-border always-visible flex-shrink-0 shadow-lg dark:shadow-white/20">
						<img src={heroPhoto} alt={translations.name.en} class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
						<span class="text-2xl sm:text-3xl md:text-4xl text-gray-500 dark:text-gray-400 hidden">📷</span>
					</div>
					<div class="animated-border always-visible px-3 sm:px-4 py-2 rounded-full border border-gray-300 dark:border-gray-600 h-fit mt-2 sm:mt-3">
						<p class="text-xs sm:text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap" data-en={translations.availability.en} data-es={translations.availability.es}>{translations.availability.en}</p>
					</div>
				</div>
				<div>
					<p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-2" data-en={translations.greeting.en} data-es={translations.greeting.es}>{translations.greeting.en}</p>
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 px-2 sm:px-0" data-en={translations.name.en} data-es={translations.name.es}>
						{translations.name.en}
					</h1>
					<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-lg mx-auto mb-4 sm:mb-6 px-2 sm:px-0" data-en="Full Stack Developer and future Systems Engineer, specialized in cross-platform development and process automation using AI and n8n. I have experience creating comprehensive clinical systems while working with agile and traditional methodologies. I focus on building modern technological solutions with rigorous attention to detail to ensure the best user and patient experience." data-es="Desarrollador Full Stack y próximo Ingeniero de Sistemas, especializado en el desarrollo multiplataforma y la automatización de procesos utilizando IA y n8n. Cuento con experiencia en la creación de sistemas clínicos integrales trabajando con metodologías ágiles y tradicionales. Centrado en construir soluciones tecnológicas modernas con una rigurosa atención al detalle para garantizar la mejor experiencia del usuario y del paciente.">
						<span class="font-semibold text-gray-900 dark:text-white">Full Stack Developer and future Systems Engineer</span> specialized in cross-platform development and process automation using <span class="font-semibold text-gray-900 dark:text-white">AI</span> and <span class="font-semibold text-gray-900 dark:text-white">n8n</span>. I have experience creating comprehensive clinical systems while working with agile and traditional methodologies. I focus on building modern technological solutions with rigorous attention to detail to ensure the best user and patient experience.
					</p>
					<div class="flex flex-wrap gap-2 sm:gap-3 justify-center px-2 sm:px-0">
						<a href="/projects" class="cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-medium rounded-full hover:animated-bg transition-all btn-press" data-en={translations.viewProjects.en} data-es={translations.viewProjects.es}>
							{translations.viewProjects.en}
						</a>
						<a href="/contact" class="animated-border cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-medium rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors btn-press" data-en={translations.getInTouch.en} data-es={translations.getInTouch.es}>
							{translations.getInTouch.en}
						</a>
					</div>
					<div class="mt-8 sm:mt-10 flex justify-center px-2 sm:px-0">
						<article class="cv-download-card group card-tilt" aria-label="Download CV card">
							<div class="cv-download-card-inner">
								<div class="text-gray-50 text-left">
									<span class="cv-initials">Jr</span>
									<p class="cv-role" data-en={translations.roleTitle.en} data-es={translations.roleTitle.es}>{translations.roleTitle.en}</p>
								</div>
								<div class="flex gap-3 items-center">
									<!-- Luis Garnica CV downloads (ES / EN) -->
									<a href={luisCvEs} download="CV_Luis_Garnica.pdf" class="cv-download-button btn-press" data-en="Download CV (ES)" data-es="Descargar CV (ES)">
										<span>ES</span>
									</a>

									<a href={luisCvEn} download="CV_Luis_Garnica_EN.pdf" class="cv-download-button btn-press" data-en="Download CV (EN)" data-es="Descargar CV (EN)">
										<span>EN</span>
									</a>
								</div>
							</div>

							<svg class="cv-avatar cv-avatar-main float-slow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" aria-hidden="true"><path d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"/></svg>
							<svg class="cv-avatar cv-avatar-accent float-slow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" aria-hidden="true"><path d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"/></svg>
						</article>
					</div>
				</div>
			</div>
		</section>

